{
  "name": "@tenkacloud/catalog-scanner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": "./src/index.ts",
  "bin": {
    "tenkacloud-catalog-scan": "src/cli.ts"
  },
  "scripts": {
    "dev": "bun src/cli.ts --help",
    "build": "bun build src/index.ts src/cli.ts --outdir dist --target bun",
    "scan": "bun src/cli.ts",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@tenkacloud/simulator-contracts": "workspace:*",
    "yaml": "2.8.2"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
