{
  "name": "@tenkacloud/simulator-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": "./src/index.ts",
  "scripts": {
    "dev": "bun src/bin.ts",
    "build": "bun build src/bin.ts src/index.ts --outdir dist --target bun",
    "test": "bun test test",
    "test:coverage": "bun test --coverage test",
    "typecheck": "tsc --noEmit",
    "verify:ssm-plugin": "bun scripts/verify-ssm-plugin.ts"
  },
  "dependencies": {
    "@tenkacloud/simulator-api": "workspace:*",
    "@tenkacloud/simulator-contracts": "workspace:*",
    "@tenkacloud/simulator-core": "workspace:*",
    "@tenkacloud/simulator-provider-aws": "workspace:*",
    "@tenkacloud/simulator-provider-azure": "workspace:*",
    "@tenkacloud/simulator-provider-gcp": "workspace:*",
    "@tenkacloud/simulator-provider-sakura": "workspace:*",
    "@tenkacloud/simulator-workload-runner": "workspace:*",
    "hono": "4.12.25"
  }
}
