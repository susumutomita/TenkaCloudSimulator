{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tenkacloud.dev/simulator/v1/event-page.schema.json",
  "title": "Simulator event replay page",
  "type": "object",
  "required": ["events", "nextCursor"],
  "properties": {
    "events": {
      "type": "array",
      "maxItems": 100,
      "items": {
        "$ref": "https://schemas.tenkacloud.dev/simulator/v1/event.schema.json"
      }
    },
    "nextCursor": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    }
  },
  "additionalProperties": true
}
