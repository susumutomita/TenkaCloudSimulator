{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tenkacloud.dev/simulator/v1/capabilities.schema.json",
  "title": "Simulator capabilities",
  "$defs": {
    "lifecycleOperation": {
      "type": "string",
      "enum": ["deploy", "delete", "get", "capabilities", "world"]
    },
    "engine": {
      "type": "object",
      "required": ["operations"],
      "properties": {
        "operations": {
          "type": "array",
          "items": { "$ref": "#/$defs/lifecycleOperation" },
          "uniqueItems": true
        },
        "resources": {
          "type": "array",
          "items": {
            "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
          },
          "uniqueItems": true
        },
        "fidelity": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/fidelitySet"
        },
        "constraints": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/jsonObject"
        }
      },
      "additionalProperties": true
    },
    "provider": {
      "type": "object",
      "required": ["engines"],
      "properties": {
        "engines": {
          "type": "object",
          "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
          "additionalProperties": { "$ref": "#/$defs/engine" }
        }
      },
      "additionalProperties": true
    },
    "capability": {
      "type": "object",
      "required": [
        "provider",
        "service",
        "resourceType",
        "operation",
        "fidelity"
      ],
      "properties": {
        "provider": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "engine": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "service": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "resourceType": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "operation": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "fidelity": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/fidelitySet"
        },
        "constraints": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/jsonObject"
        }
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "required": ["protocolVersion", "simulatorVersion", "providers"],
  "properties": {
    "protocolVersion": { "const": "2026-07-11" },
    "simulatorVersion": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "providers": {
      "type": "object",
      "propertyNames": { "pattern": "^[a-z][a-z0-9-]*$" },
      "additionalProperties": { "$ref": "#/$defs/provider" }
    },
    "capabilities": {
      "type": "array",
      "items": { "$ref": "#/$defs/capability" }
    },
    "constraints": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/jsonObject"
    }
  },
  "additionalProperties": true
}
