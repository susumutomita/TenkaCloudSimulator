    "metadata": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/jsonValue"
    },
    "simulationOverlay": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/simulation-overlay.schema.json"
