  "$id": "https://schemas.tenkacloud.dev/simulator/v1/create-deployment-request.schema.json",
  "title": "Create simulator deployment request",
  "type": "object",
  "required": ["problemId", "runtime", "templateBody"],
  "properties": {
    "problemId": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
