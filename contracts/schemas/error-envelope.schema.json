{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tenkacloud.dev/simulator/v1/error-envelope.schema.json",
  "title": "Simulator error envelope",
  "$defs": {
    "errorCode": {
      "type": "string",
      "enum": [
        "ValidationFailed",
        "NotFound",
        "Conflict",
        "UnauthorizedOperation",
        "UnsupportedCapability",
        "NotImplemented",
        "IdempotencyConflict",
        "QuotaExceeded",
        "SnapshotIncompatible",
        "ProtocolVersionMismatch",
        "WorkloadEffectFailed",
        "InternalError"
      ]
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "message": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "provider": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "service": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "resourceType": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "operation": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "requiredFidelity": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/fidelitySet"
        },
        "availableFidelity": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/fidelitySet"
        },
        "source": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/sourceLocation"
        }
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "required": ["error"],
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "message", "requestId", "retryable", "diagnostics"],
      "properties": {
        "code": { "$ref": "#/$defs/errorCode" },
        "message": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "requestId": {
          "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
        },
        "retryable": { "type": "boolean" },
        "diagnostics": {
          "type": "array",
          "items": { "$ref": "#/$defs/diagnostic" }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
