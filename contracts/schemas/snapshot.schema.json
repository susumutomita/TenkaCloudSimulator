{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.tenkacloud.dev/simulator/v1/snapshot.schema.json",
  "title": "Simulator snapshot",
  "type": "object",
  "required": [
    "snapshotVersion",
    "protocolVersion",
    "worldId",
    "namespace",
    "seed",
    "clock",
    "lastSequence",
    "resourceGraph",
    "providerProjections",
    "hash",
    "integrityProof"
  ],
  "properties": {
    "snapshotVersion": { "const": "2" },
    "protocolVersion": { "const": "2026-07-11" },
    "worldId": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "namespace": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/namespace"
    },
    "seed": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/nonEmptyString"
    },
    "clock": { "type": "string", "format": "date-time" },
    "lastSequence": { "type": "integer", "minimum": 0 },
    "resourceGraph": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/jsonObject"
    },
    "providerProjections": {
      "type": "object",
      "additionalProperties": {
        "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/jsonObject"
      }
    },
    "scheduledTransitions": {
      "type": "array",
      "items": {
        "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/jsonObject"
      }
    },
    "hash": {
      "$ref": "https://schemas.tenkacloud.dev/simulator/v1/common.schema.json#/$defs/sha256"
    },
    "integrityProof": {
      "description": "Server-authenticated proof over the canonical version 2 snapshot envelope excluding this property. Unsigned version 1 snapshots are intentionally rejected.",
      "type": "object",
      "required": ["version", "algorithm", "value"],
      "properties": {
        "version": { "const": "1" },
        "algorithm": { "const": "HMAC-SHA256" },
        "value": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_-]{43}$"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
