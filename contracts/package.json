{
  "name": "@tenkacloud/simulator-contracts",
  "version": "0.1.0",
  "description": "Versioned wire contracts and schema-backed validators for TenkaCloud Simulator",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schemas": "./src/schemas.ts",
    "./schemas/*.schema.json": "./schemas/*.schema.json",
    "./openapi.yaml": "./openapi.yaml"
  },
  "files": [
    "src",
    "schemas",
    "openapi.yaml"
  ],
  "scripts": {
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "bun test test",
    "test:coverage": "bun test --coverage test"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "typescript": "^5.9.3"
  }
}
