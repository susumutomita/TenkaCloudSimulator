{
  "name": "TenkaCloud Simulator",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "remoteUser": "vscode",
  "postCreateCommand": "make install_ci",
  "forwardPorts": [7777],
  "portsAttributes": {
    "7777": {
      "label": "TenkaCloud Simulator",
      "onAutoForward": "notify",
      "protocol": "http",
      "visibility": "private"
    }
  }
}
